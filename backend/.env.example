# Database Configuration
DATABASE_URL=mongodb://localhost:27017/nova_ai
MONGODB_DB_NAME=
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_CONNECT_TIMEOUT_MS=5000
MONGODB_SOCKET_TIMEOUT_MS=10000
MONGODB_RETRY_ATTEMPTS=3
MONGODB_RETRY_DELAY_SECONDS=2.0
MONGODB_RETRY_BACKOFF_MULTIPLIER=2.0
MONGODB_RETRY_MAX_DELAY_SECONDS=15.0
MONGODB_REQUIRED=false

# JWT Configuration
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Provider Keys
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
PERPLEXITY_API_KEY=
TOGETHER_API_KEY=

# Provider Selection
AI_PROVIDER=auto
AI_MODEL=
OPENAI_CHAT_MODEL=gpt-4-turbo-preview
OPENAI_CODE_MODEL=gpt-4-turbo-preview
OPENAI_EXPLAIN_MODEL=gpt-4-turbo-preview
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_IMAGE_QUALITY=hd
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
OPENAI_EMBEDDING_DIM=1536
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_NUM_PREDICT=512
OLLAMA_NUM_CTX=2048

# Generation / Timeout Settings
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=2048
AI_REQUEST_TIMEOUT_SECONDS=60
AI_IMAGE_REQUEST_TIMEOUT_SECONDS=180
AI_DEBUG_LOGGING=true
AI_LOG_PREVIEW_CHARS=400

# Rate Limiting
REDIS_URL=redis://localhost:6379
RATE_LIMIT_ENABLED=true
CHAT_RATE_LIMIT_REQUESTS=20
CHAT_RATE_LIMIT_WINDOW_SECONDS=60
IMAGE_RATE_LIMIT_REQUESTS=10
IMAGE_RATE_LIMIT_WINDOW_SECONDS=3600

# CORS / Uploads
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# Conversation Memory
CONVERSATION_SUMMARY_MIN_MESSAGES=8
CONVERSATION_SUMMARY_REFRESH_INTERVAL=4
CONVERSATION_SUMMARY_RECENT_MESSAGES=18

# Vector / Search Settings
VECTOR_DB_TYPE=lexical
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=

# App Settings
APP_NAME=NOVA AI
APP_VERSION=1.0.0
DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
