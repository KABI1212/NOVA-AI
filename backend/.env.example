# App Configuration
APP_NAME=NOVA AI
APP_VERSION=1.0.0
# Local dev can use DEBUG=true.
# Render / production should use DEBUG=false.
DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
UVICORN_ACCESS_LOG=false
SUPPRESS_32BIT_CRYPTO_WARNING=true

# Database Configuration
DATABASE_URL=mongodb://localhost:27017/nova_ai
MONGODB_DB_NAME=
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_CONNECT_TIMEOUT_MS=5000
MONGODB_SOCKET_TIMEOUT_MS=10000
MONGODB_RETRY_ATTEMPTS=3
MONGODB_RETRY_DELAY_SECONDS=2.0
MONGODB_RETRY_BACKOFF_MULTIPLIER=2.0
MONGODB_RETRY_MAX_DELAY_SECONDS=15.0
MONGODB_REQUIRED=false

# JWT Configuration
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_OTP_EXPIRE_MINUTES=5
AUTH_OTP_LENGTH=6
AUTH_ALLOW_PASSWORD_ONLY_FALLBACK=false
AUTH_EXPOSE_DEBUG_OTP=false

# Email / OTP Delivery
# Production recommendation: use SMTP and keep EMAIL_PROVIDER=smtp.
# The backend supports both the new variable names below and legacy aliases.
EMAIL_PROVIDER=
EMAIL_FROM=
# Legacy alias (optional)
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=NOVA AI
EMAIL_REPLY_TO=
SMTP_HOST=
SMTP_PORT=587
# Preferred names
SMTP_USER=
SMTP_PASS=
# Legacy aliases (optional)
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=10
SENDGRID_API_KEY=

# SMTP example (Gmail app password)
# EMAIL_PROVIDER=smtp
# EMAIL_FROM=yourgmail@gmail.com
# EMAIL_FROM_NAME=NOVA AI
# EMAIL_REPLY_TO=yourgmail@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=yourgmail@gmail.com
# SMTP_PASS=your-16-char-google-app-password
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false

# SendGrid example
# EMAIL_PROVIDER=sendgrid
# EMAIL_FROM_ADDRESS=verified-sender@yourdomain.com
# EMAIL_FROM_NAME=NOVA AI
# EMAIL_REPLY_TO=verified-sender@yourdomain.com
# SENDGRID_API_KEY=SG.your-sendgrid-api-key

# Provider Keys
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
PERPLEXITY_API_KEY=
TOGETHER_API_KEY=

# Provider Selection
AI_PROVIDER=auto
AI_IMAGE_PROVIDER=
IMAGE_PROMPT_ENHANCER_PROVIDER=
AI_MODEL=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_CODE_MODEL=gpt-4o
OPENAI_EXPLAIN_MODEL=gpt-4o
GEMINI_CHAT_MODEL=gemini-2.5-flash
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_IMAGE_QUALITY=hd
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
OPENAI_EMBEDDING_DIM=1536
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_IMAGE_MODEL=sourceful/riverflow-v2-fast-preview
# Local development only. On Render or Vercel-backed deployments, leave this pointing at
# a real reachable Ollama server or rely on cloud provider keys instead.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_NUM_PREDICT=512
OLLAMA_NUM_CTX=2048

# Generation / Timeout Settings
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=2048
AI_FAST_MAX_TOKENS=320
AI_REQUEST_TIMEOUT_SECONDS=60
AI_IMAGE_REQUEST_TIMEOUT_SECONDS=180
AI_DEBUG_LOGGING=false
AI_LOG_PREVIEW_CHARS=400
# Keep normal chat provider-first. Turn this on only if you want latest/current
# questions to automatically pull web results before the AI answers.
CHAT_AUTO_WEB_SEARCH_IN_CHAT=false
# Keep normal chat behaving like a direct LLM reply. Turn this on only if you
# want chat to fall back to web-backed answers when the model fails or replies
# with stale cutoff language. Explicit Web Search mode still works either way.
CHAT_AUTO_WEB_FALLBACK_IN_CHAT=false

# Rate Limiting
REDIS_URL=redis://localhost:6379
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WARN_ON_MEMORY_FALLBACK=false
CHAT_RATE_LIMIT_REQUESTS=20
CHAT_RATE_LIMIT_WINDOW_SECONDS=60
IMAGE_RATE_LIMIT_REQUESTS=10
IMAGE_RATE_LIMIT_WINDOW_SECONDS=3600

# CORS / Uploads
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN_REGEX=^https://([A-Za-z0-9-]+\.)*(vercel\.app|onrender\.com)$
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# Conversation Memory
CONVERSATION_SUMMARY_MIN_MESSAGES=8
CONVERSATION_SUMMARY_REFRESH_INTERVAL=4
CONVERSATION_SUMMARY_RECENT_MESSAGES=18

# Vector / Search Settings
VECTOR_DB_TYPE=lexical
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
